default_platform(:ios)

# nomameshi 系 fastlane 標準を tonton (Flutter) 向けに調整したもの。
# - 署名: fastlane match (storage = DELAxGithub/fastlane-match private repo)
# - SUPABASE_URL / SUPABASE_ANON_KEY / GEMINI_API_KEY は ../.env から読む

APP_BUNDLE_ID    = "com.HiroshiKodera.tonton"
APP_TEAM_ID      = "Z88477N5ZU"
MATCH_GIT_URL    = "https://github.com/DELAxGithub/fastlane-match"
MATCH_PROFILE_ENV = "sigh_#{APP_BUNDLE_ID}_appstore"

def asc_api_key
  %w[ASC_KEY_ID ASC_ISSUER_ID ASC_KEY_PATH].each do |k|
    UI.user_error!("#{k} is not set") if (ENV[k] || "").empty?
  end
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: ENV["ASC_KEY_PATH"]
  )
end

def match_params(readonly:)
  {
    type: "appstore",
    storage_mode: "git",
    git_url: MATCH_GIT_URL,
    app_identifier: APP_BUNDLE_ID,
    team_id: APP_TEAM_ID,
    force_legacy_encryption: true,
    readonly: readonly
  }
end

platform :ios do
  desc "Sync App Store Distribution cert + provisioning profile via match"
  lane :sync_certs do
    match(match_params(readonly: false).merge(api_key: asc_api_key))
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    # ルートの .env を読み込み (SUPABASE_URL 等)
    env_path = File.expand_path("../../.env", __dir__)
    if File.exist?(env_path)
      File.readlines(env_path).each do |line|
        line = line.strip
        next if line.empty? || line.start_with?("#")
        key, value = line.split("=", 2)
        next if key.nil? || value.nil?
        ENV[key.strip] ||= value.strip.gsub(/\A["']|["']\z/, "")
      end
    end

    supabase_url = ENV["SUPABASE_URL"] || ""
    supabase_anon_key = ENV["SUPABASE_ANON_KEY"] || ""
    gemini_api_key = ENV["GEMINI_API_KEY"] || ""

    UI.user_error!("SUPABASE_URL is not set") if supabase_url.empty?
    UI.user_error!("SUPABASE_ANON_KEY is not set") if supabase_anon_key.empty?

    api_key = asc_api_key

    # match で Distribution cert + provisioning profile を install (readonly)
    match(match_params(readonly: true).merge(api_key: api_key))

    profile_name = ENV[MATCH_PROFILE_ENV] || ""
    if profile_name.empty?
      UI.user_error!("match did not export #{MATCH_PROFILE_ENV}; cannot resolve provisioning profile")
    end

    # Flutter build (no codesign; fastlane が後で署名)
    sh(
      "cd ../.. && flutter build ios --release --no-codesign " \
      "--dart-define=SUPABASE_URL=#{supabase_url} " \
      "--dart-define=SUPABASE_ANON_KEY=#{supabase_anon_key} " \
      "--dart-define=GEMINI_API_KEY=#{gemini_api_key}"
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        teamID: APP_TEAM_ID,
        signingStyle: "manual",
        provisioningProfiles: {
          APP_BUNDLE_ID => profile_name
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
